//El programa evalúa el valor numérico de la variable 'dia' y  la estructura 'switch' compara este número con cada caso ('case') del 1 al 7.

let dia = 3; // Cambia este valor del 1 al 7 para probar el programa

switch (dia) {
    case 1:
        console.log("Lunes");
        break;
    case 2:
        console.log("Martes");
        break;
    case 3:
        console.log("Miércoles");
        break;
    case 4:
        console.log("Jueves");
        break;
    case 5:
        console.log("Viernes");
        break;
    case 6:
        console.log("Sábado");
        break;
    case 7:
        console.log("Domingo");
        break;
    default:
        console.log("Número de día inválido. Debe ser del 1 al 7.");
}
